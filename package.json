{
  "name": "tessyn",
  "version": "0.3.0",
  "description": "Background daemon that indexes Claude Code sessions into searchable SQLite with full-text search. Cross-session search, session history, and CLI for developer workflow tools.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "skills"
  ],
  "bin": {
    "tessyn": "./dist/cli/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "dev": "tsc --watch",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run lint && npm test",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest watch test/unit",
    "lint": "eslint src/ test/",
    "start": "node dist/daemon/index.js",
    "tessyn": "node dist/cli/index.js"
  },
  "keywords": [
    "developer-tools",
    "workflow",
    "claude-code",
    "session-management",
    "search",
    "sqlite",
    "daemon"
  ],
  "author": "Roman Still",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sapph1re/tessyn.git"
  },
  "homepage": "https://github.com/sapph1re/tessyn#readme",
  "bugs": {
    "url": "https://github.com/sapph1re/tessyn/issues"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "env-paths": "^4.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
