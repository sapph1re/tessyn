{
  "name": "tessyn",
  "version": "0.1.0",
  "description": "The developer workflow operating system.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "tessyn": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest watch test/unit",
    "lint": "eslint src/ test/",
    "start": "node dist/daemon/index.js",
    "tessyn": "node dist/cli/index.js"
  },
  "keywords": [
    "developer-tools",
    "workflow",
    "claude-code",
    "session-management"
  ],
  "author": "Roman Still",
  "license": "MIT",
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "env-paths": "^4.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
