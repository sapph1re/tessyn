{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "vscode": ["./node_modules/@types/vscode"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/webview/**", "src/test/**", "node_modules"]
}
